# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Provider ───────────────────────────────────────────────────────────────────
# Em modo multi-tenant o provider é determinado automaticamente pelo usuário autenticado.
# Deixe "mock" para desenvolvimento local sem conta Meta.
ADS_PROVIDER=mock

# ── Meta Marketing API (single-tenant legado) ─────────────────────────────────
# Usado apenas quando ADS_PROVIDER=meta sem autenticação OAuth.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

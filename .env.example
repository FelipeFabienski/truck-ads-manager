# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Ads Provider ───────────────────────────────────────────────────────────────
# "mock" — in-memory sem dependências externas (padrão para desenvolvimento)
# "meta" — Meta Marketing API (requer META_ACCESS_TOKEN e META_AD_ACCOUNT_ID)
ADS_PROVIDER=meta

# ── Meta Marketing API ────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_GRAPH_API_VERSION=v23.0

# ── Geração de copy ───────────────────────────────────────────────────────────
# false (padrão) — usa templates fixos, sem dependência de API externa
# true  — usa Claude (Anthropic); requer ANTHROPIC_API_KEY configurada
ENABLE_AI_COPY=false
ANTHROPIC_API_KEY=

# ── JWT ────────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# Se SMTP_HOST estiver vazio, emails são apenas logados (modo dev).
#
# Gmail (App Password): SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true
# Brevo (300/dia grátis): SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_USE_TLS=true
# Porta 465 (SSL): SMTP_PORT=465  SMTP_USE_SSL=true  SMTP_USE_TLS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@seudominio.com
SMTP_FROM_NAME=Império Caminhões
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── Frontend / Email links ─────────────────────────────────────────────────────
# URL base do frontend — usada para gerar links nos emails.
FRONTEND_URL=https://truck-ads-manager-production.up.railway.app
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=30

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
